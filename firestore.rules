rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId (Firebase Auth UID)
    // Fields:
    //   - monthlySalary: number (required)
    //   - familyMembers: number (required)
    //   - maritalStatus: string (required, enum: single, married, not_specified)
    //   - fixedExpenses: map (rent, electricity, water, gas, transportation, internet, mobile)
    //   - optionalExpenses: map (streaming, education, medical)
    //   - dailyExpenses: map (foodDrink, cafe, medical, travel)
    //   - debts: list of maps
    //   - annualExpenses: list of maps
    //   - preferences: map (savingPriority, riskTolerance, emergencyFundPercentage, monthlyPriorities)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUserProfile(data) {
      return data.keys().hasAll(['monthlySalary', 'familyMembers', 'maritalStatus']) &&
             data.monthlySalary is number && data.monthlySalary >= 0 &&
             data.familyMembers is number && data.familyMembers >= 1 &&
             data.maritalStatus in ['single', 'married', 'not_specified'];
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUserProfile(request.resource.data);
      allow update: if isOwner(userId) && isValidUserProfile(request.resource.data);
      allow delete: if isOwner(userId);
    }
  }
}
