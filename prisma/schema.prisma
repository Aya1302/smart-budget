// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./modaber.db"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  profile   Profile?
  expenses  Expense[]
}

model Profile {
  id                      String   @id @default(uuid())
  userId                  String   @unique
  user                    User     @relation(fields: [userId], references: [id])
  familyMembers           Int
  maritalStatus           String
  livingCostLevel         String
  incomeStability         String
  monthlySalary           Float
  fixedExpenses           String   // JSON string
  optionalExpenses        String   // JSON string
  debts                   String   // JSON string
  annualExpenses          String   // JSON string
  monthlyPriorities       String   // JSON string (comma separated or JSON)
  emergencyFundPercentage Int
  savingPriority          String
  riskTolerance           String
  updatedAt               DateTime @updatedAt
}

model Expense {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  category    String   // food, cafe, medicine, travel, other
  amount      Float
  description String?
  date        DateTime @default(now())
}
